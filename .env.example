# Server Configuration
PORT=3000

# SQL Server Configuration
# DEV (Windows local): deixe MSSQL_USER/MSSQL_PASSWORD vazios para usar Trusted Connection.
# PROD (Cloud Run/Linux): preencha MSSQL_USER e MSSQL_PASSWORD.
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=hls_api
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_TRUST_SERVER_CERT=true
NODE_ENV=development

# SMTP Configuration (necessário em produção para envio de e-mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="HLS API <no-reply@seudominio.com>"

# Optional: PostgreSQL Configuration (uncomment to use PostgreSQL instead)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=password
# PGDATABASE=hls_api
